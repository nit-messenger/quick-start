# =====================================================================
# Nit Family Messenger Configuration
# =====================================================================

# Database Configuration (PostgreSQL)
DB_HOST=db
DB_PORT=5432
DB_USER=nit
DB_PASSWORD=nitpass
DB_NAME=nit

# Server Domain Configuration
# Set this to your external IP or Domain (e.g. messenger.domain.com)
SERVER_DOMAIN=localhost

# JWT Credentials
# Change these values in production setups!
JWT_SECRET=supersecretjwtkeyfornitmessengerapi
JWT_REFRESH_SECRET=supersecretjwtrefreshkeyfornitmessengerapi

# Media Storage Config
# Limit in Bytes (default is 2GB)
MEDIA_STORAGE_PATH=/app/uploads
MAX_UPLOAD_BYTES=2147483648

# WebRTC ICE Server config
TURN_SERVER_ADDR=
TURN_USERNAME=
TURN_PASSWORD=

# Trusted Proxy Config
# Secret key shared between Proxy Nodes and Backend
PROXY_KEY=supersecretproxyauthorizationtoken

# Standalone Proxy Server Port configuration
PROXY_PORT=8081
